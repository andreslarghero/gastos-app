PORT=3001

# URL base para llamadas del frontend al backend.
# En despliegue típico donde frontend y backend van juntos, dejá vacío.
PUBLIC_API_BASE_URL=

# Configuración pública de Supabase para el frontend.
PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY

# Configuración privada del backend (ya usada por supabaseClient.js).
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY
